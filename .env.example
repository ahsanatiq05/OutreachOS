# ── OutreachOS Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already in .gitignore.

# NVIDIA NIM API Key (required for AI email generation)
# Get yours at: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-your-key-here

# Your unsubscribe contact email (shown in List-Unsubscribe header)
UNSUBSCRIBE_EMAIL=unsubscribe@yourdomain.com

# Public server URL for email open-tracking pixel (optional)
# Leave blank to use Flask's request.url_root automatically
SERVER_URL=

# SQLite database file path (optional, defaults to agency.db)
# DATABASE_URL=agency.db

# Port (set automatically by cloud platforms like Heroku/Render)
# PORT=5000
